# ── Lightning (required) ───────────────────────────────────────────────────────
# NWC URL for your Alby Hub wallet (provides makeInvoice / payInvoice)
ALBY_NWC_URL=nostr+walletconnect://...

# ── Database (required) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bitpos

# ── Auth (required) ────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
SESSION_SECRET=change-me-in-production

# ── Card Shop (required for orders to process) ─────────────────────────────────
# Secret key from your Printags dashboard (used as Bearer token)
PRINTAGS_SECRET_KEY=

# Account UUID from your Printags dashboard
PRINTAGS_ACCOUNT_ID=

# Shared secret for validating Printags webhook signatures
# Set this in your Printags dashboard under Webhook Settings → Signing Secret.
# The signature arrives as: X-Printags-Signature: sha256=<hex>
PRINTAGS_WEBHOOK_SECRET=

# ── Server (optional) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (default: localhost dev ports)
CORS_ORIGINS=http://localhost:8081,http://localhost:3000
PORT=8080
